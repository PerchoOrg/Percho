{
  "name": "percho-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "web:dev": "pnpm --filter @percho/web dev",
    "web:build": "pnpm --filter @percho/web build",
    "web:lint": "pnpm --filter @percho/web lint",
    "web:typecheck": "pnpm --filter @percho/web typecheck",
    "web:test": "pnpm --filter @percho/web test",
    "mobile:start": "pnpm --filter @percho/mobile start",
    "db:push": "pnpm --filter @percho/web db:push",
    "db:reset": "pnpm --filter @percho/web db:reset",
    "db:types": "pnpm --filter @percho/web db:types"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
