# ─────────────────────────────────────────────────────
# Percho — Environment Variables Template
# Copy to .env.local for local dev. NEVER commit .env.local.
# Production values live in Vercel project settings.
# ─────────────────────────────────────────────────────

# ─── Supabase ───────────────────────────────────────
# From: Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...

# Service role key — SERVER ONLY. Never expose to client. Bypasses RLS.
# Used only by webhook handlers and admin scripts.
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# ─── Cloudflare Stream ──────────────────────────────
# From: Cloudflare dashboard → Stream → API tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
# Webhook signing secret — set after webhook is registered
CLOUDFLARE_STREAM_WEBHOOK_SECRET=
# Customer subdomain for HLS playback URLs (e.g. customer-abc123)
NEXT_PUBLIC_CLOUDFLARE_STREAM_CUSTOMER_SUBDOMAIN=

# ─── Resend (transactional email) ───────────────────
RESEND_API_KEY=re_xxx
# Verified sender on vicinities.cc
RESEND_FROM_EMAIL=notifications@vicinities.cc

# ─── Anthropic (AI listing copy) ────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
# Pin to sonnet for V1 cost control
ANTHROPIC_MODEL=claude-sonnet-4-5

# ─── Google Maps / Places ───────────────────────────
# Browser-restricted key — ONLY allow vicinities.cc + localhost referrers
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# Server-side key for Places autocomplete proxy (no referrer restriction)
GOOGLE_PLACES_API_KEY=

# ─── App config ─────────────────────────────────────
# Public URL of this deployment (used in OG tags, email links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── MLS: Bridge Interactive / FMLS ─────────────────
# Set once broker completes Bridge portal + FMLS approval.
# Bridge issues a long-lived server token; keep server-side only (never
# ship to the browser). See docs/mls-integration/README.md.
BRIDGE_SERVER_TOKEN=***
# FMLS dataset id assigned by Bridge on approval (likely "fmls").
BRIDGE_DATASET_ID=fmls
# Bridge API base URL. Override only for local mocking.
BRIDGE_BASE_URL=https://api.bridgedataoutput.com/api/v2
